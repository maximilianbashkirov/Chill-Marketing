# Environment variables for Chill Marketing AI Bot

# Application
APP_NAME="Chill Marketing AI Bot"
APP_VERSION="1.0.0"
DEBUG=True

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/chillbot

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=marketing_cases

# LLM API Keys (fill these in when ready)
# GigaChat credentials (base64 encoded from developer.sberbank.ru)
GIGACHAT_CREDENTIALS=MDE5ZTE4OGEtNDgwZS03NDI4LTlmOTktYTQ0NDVkNTc2YTRjOjdlMzZkNzllLTdhYWEtNGY4ZS05YWIzLTY5ODIxODgwYjk0Nw==
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL_CERTS=False
GIGACHAT_MODEL=GigaChat
GIGACHAT_TIMEOUT=60.0

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
